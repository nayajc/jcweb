# Contentful Content Delivery API credentials.
# Copy this file to .env.local and fill in real values (never commit .env.local).

# Space ID from Contentful: Settings → API keys
CONTENTFUL_SPACE_ID=

# Content Delivery API - access token (read-only, published content)
CONTENTFUL_ACCESS_TOKEN=

# Shared secret for the on-demand revalidation webhook (Phase 5b, optional).
# Sent by Contentful as an Authorization header; validated by the API route.
CONTENTFUL_REVALIDATE_SECRET=
